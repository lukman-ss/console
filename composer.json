{
    "name": "lukman-ss/console",
    "description": "A lightweight standalone PHP Console package",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "console",
        "cli",
        "command",
        "terminal"
    ],
    "homepage": "https://github.com/lukman-ss/console",
    "support": {
        "issues": "https://github.com/lukman-ss/console/issues",
        "source": "https://github.com/lukman-ss/console"
    },
    "authors": [
        {
            "name": "Lukman",
            "email": "lukmanumb1@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Lukman\\Console\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lukman\\Console\\Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/phpunit/phpunit/phpunit"
    }
}
